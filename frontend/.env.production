# Vite lo lee automáticamente en `npm run build` (modo production).
# En producción el frontend y la API van en el mismo dominio (nginx proxya /api).
VITE_API_BASE=/api

# Dominio público del sitio. Es la ÚNICA fuente de la URL para el SEO: las
# etiquetas canonical/Open Graph del index.html, el sitemap.xml y el robots.txt
# se generan desde acá. Al pasar al dominio real de producción, cambiar SOLO
# esta línea (ej: https://ingenioblocks.cl) y reconstruir.
VITE_SITE_URL=https://ecommercesoledad.duckdns.org
