# ==============================================================
# Plantilla de configuración — copiar a .env y completar.
# El .env real NUNCA se sube al repositorio (está en .gitignore).
# ==============================================================

# --- Django ---
# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
# En PRODUCCION SIEMPRE False (activa HTTPS forzado, HSTS, cookies seguras, API solo JSON)
DEBUG=True
# Dominios extra separados por coma (ej: tienda.ingenioblocks.cl)
ALLOWED_HOSTS=
# En producción: ruta secreta para el admin, ej: gestion-interna-x7k2/
DJANGO_ADMIN_URL=admin/

# --- URLs ---
# Producción: https://api.midominio.cl (o el mismo dominio). Dev: URL del túnel para MercadoPago.
BACKEND_PUBLIC_URL=
# Producción: https://www.midominio.cl . Dev: http://localhost:5173
FRONTEND_URL=http://localhost:5173

# --- Transbank Webpay ---
# INTEGRACION (pruebas, default) o PRODUCCION. En producción, poner las llaves reales del comercio.
TBK_ENVIRONMENT=INTEGRACION
TBK_API_KEY_ID=
TBK_API_KEY_SECRET=

# --- MercadoPago ---
# Access Token: de PRUEBA para desarrollo, el real de la clienta para producción.
MP_ACCESS_TOKEN=

# --- Shipit ---
SHIPIT_EMAIL=
SHIPIT_TOKEN=

# --- OpenFactura (Haulmer) ---
# Vacío/placeholder => ambiente dev público (boletas simuladas).
# Producción: API key real + OPENFACTURA_API_BASE=https://api.haulmer.com
OPENFACTURA_API_KEY=
# OPENFACTURA_API_BASE=https://api.haulmer.com

# --- Email (producción: SMTP de la clienta) ---
# Dev: dejar vacío (los correos se imprimen en la consola del servidor).
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.midominio.cl
# EMAIL_PORT=587
# EMAIL_HOST_USER=no-reply@midominio.cl
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=IngenioBlocks <no-reply@midominio.cl>
