# ============================================================================
# .env de PRODUCCIÓN — ingenioblocks.com
#
# Copiar a /srv/ingenioblocks/.env y completar lo marcado con <<< >>>.
#   chmod 600 /srv/ingenioblocks/.env     (que no lo lea otro usuario)
#
# OJO: las pasarelas SIGUEN en sus ambientes de integración/prueba (no se mueve
# plata real y las boletas son simuladas, sin validez ante el SII). Antes de
# vender de verdad hay que cambiar las credenciales marcadas como "PRUEBA" por
# las reales de la clienta.
# ============================================================================

# --- Django ---
DEBUG=False

# Generar una propia y no reutilizar la de desarrollo:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=<<< pegar la clave generada >>>

# El www se incluye porque nginx lo redirige al apex, pero la petición igual
# pasa por Django y debe estar permitida.
ALLOWED_HOSTS=ingenioblocks.com,www.ingenioblocks.com
FRONTEND_URL=https://ingenioblocks.com
BACKEND_PUBLIC_URL=https://ingenioblocks.com

# La ruta del panel de Django admin. Cambiarla saca de la mira los bots que
# escanean /admin/ a ciegas. El panel de la clienta vive en /gestion/ aparte.
DJANGO_ADMIN_URL=escritorio-ib/

# Cuántos proxies hay delante de Django. Con nginx: 1.
# Es lo que permite leer la IP real del visitante; sin esto el bloqueo por
# intentos fallidos bloquearía a TODOS a la vez. Ver deploy/nginx.conf.
PROXY_COUNT=1

# --- Base de datos ---
# Postgres. NO dejar esto sin definir en producción: sin DB_NAME la app cae a
# SQLite, que bloquea la base entera en cada escritura — dos personas comprando
# al mismo tiempo pueden toparse con "database is locked". SQLite es solo para
# desarrollo en el computador.
DB_NAME=ingenioblocks
DB_USER=ingenioblocks
DB_PASSWORD=<<< clave de la base >>>
DB_HOST=127.0.0.1
DB_PORT=5432

# --- Registro de eventos ---
LOG_DIR=/srv/ingenioblocks/logs
LOG_LEVEL=INFO

# --- Transbank Webpay (PRUEBA: ambiente de integración) ---
# Credenciales públicas de integración documentadas por Transbank.
# No mueven plata. Para producción: TBK_ENVIRONMENT=PRODUCCION + las de la clienta.
TBK_ENVIRONMENT=INTEGRACION
TBK_API_KEY_ID=597055555532
TBK_API_KEY_SECRET=579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C

# --- MercadoPago (PRUEBA: credenciales de prueba de la cuenta) ---
MP_ACCESS_TOKEN=<<< copiar el mismo APP_USR-... del .env local >>>

# --- Shipit (PRUEBA) ---
# Cotiza contra la API real (las tarifas son de verdad), pero no se crean
# envíos salvo que se use la acción del panel.
SHIPIT_EMAIL=<<< copiar del .env local >>>
SHIPIT_TOKEN=<<< copiar del .env local >>>
SHIPIT_ORIGIN_COMMUNE_ID=308        # 308 = Las Condes. Confirmar la bodega real.
SHIPIT_TIMEOUT=8

# --- OpenFactura / Haulmer (PRUEBA: ambiente demo) ---
# Con una key que empieza en "test_" se usa el ambiente de desarrollo de
# Haulmer: emite boletas SIMULADAS, sin validez tributaria.
OPENFACTURA_API_KEY=test_ambiente_demo
OPENFACTURA_TIMEOUT=8

# --- Correo ---
# Mientras no esté la contraseña de aplicación de Gmail, dejar el backend de
# SMTP de Gmail, ya verificado localmente. La contraseña es la de APLICACIÓN de
# 16 caracteres (myaccount.google.com/apppasswords, con verificación en 2 pasos
# activa) — SIN espacios. La contraseña normal de la cuenta NO sirve: Gmail la
# rechaza con error 535. La clave real va acá, en el .env del servidor; nunca en
# este archivo de ejemplo (que sí se versiona).
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=contacto@ingenioblocks.com
EMAIL_HOST_PASSWORD=<<< contraseña de aplicación, 16 caracteres, sin espacios >>>
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=Ingenio Blocks <contacto@ingenioblocks.com>
CONTACT_EMAIL=contacto@ingenioblocks.com

# --- Bloqueo por intentos fallidos ---
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_MINUTES=30
